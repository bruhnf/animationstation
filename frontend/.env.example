# Frontend (Expo) environment — copy to frontend/.env for local dev.
# EXPO_PUBLIC_* vars are inlined into the JS bundle at build time by Expo CLI,
# so they are NOT secrets (a DSN is safe to expose; auth tokens are not).
# For EAS builds, set these as EAS environment variables instead — a local
# .env is only read by `npx expo start`.

# Sentry React Native (App.tsx). Unset = Sentry stays a no-op.
# Project: org "bruhnfreemancom", project "react-native" (created 2026-06-10;
# its own DSN — the backend's node-express DSN will not work).
# ⚠️ Only enable on a client that CONTAINS the RNSentry native module
# (dev client built ≥ 1.0.17 or an EAS build) — older clients crash on init.
EXPO_PUBLIC_SENTRY_DSN=
# Optional: tags events; defaults to "development" in dev builds.
EXPO_PUBLIC_SENTRY_ENVIRONMENT=
# Optional: performance tracing rate, default 0 (errors only — free-tier quota).
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=

# Source-map upload during EAS builds: org/project are configured in app.json
# (the @sentry/react-native/expo plugin block). Only ONE secret is needed,
# set as an EAS secret (never EXPO_PUBLIC_, never in the bundle):
#   SENTRY_AUTH_TOKEN  — org auth token with project:releases scope
#                        (create at sentry.io → Settings → Auth Tokens)
