    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^9.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "expo-constants": "18.0.13",
    "ws": "^8.18.3"
