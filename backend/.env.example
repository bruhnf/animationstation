# Database
DATABASE_URL="postgresql://animationstation:animationstation_dev@localhost:5432/animationstation_db"

# JWT - generate with: openssl rand -hex 32
JWT_SECRET="replace_with_random_hex_32"
JWT_REFRESH_SECRET="replace_with_different_random_hex_32"
# Refresh-token rotation + reuse detection. ON in dev + prod as of 2026-06-10.
# Rotation is crash-tolerant server-side: a rotated token is tombstoned (not
# deleted) and a replay whose successor was never itself used is recovered with
# a fresh token instead of revoking the family — so even clients that don't
# persist the rotated token keep working. Safe to enable; revert with "false".
REFRESH_TOKEN_ROTATION="false"

# App
PORT=3000
NODE_ENV=development
# For production, set to: https://animationstation.ai
ALLOWED_ORIGINS="http://localhost:8081,exp://localhost:8081"

# Admin
ADMIN_API_KEY="replace_with_secure_admin_key"

# AWS S3
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="animationstation-uploads-dev"

# Redis
REDIS_URL="redis://localhost:6379"

# xAI Grok
GROK_API_KEY="your_xai_api_key"
GROK_API_URL="https://api.x.ai/v1"

# Email (AWS SES via its SMTP interface — the app sends over plain SMTP/nodemailer)
SES_FROM_ADDRESS="noreply@animationstation.ai"
# Production: AWS SES SMTP — host email-smtp.<region>.amazonaws.com, port 465,
# user/pass = SES SMTP credentials (NOT IAM keys). For local dev you can instead
# point these at Ethereal (https://ethereal.email) or Mailtrap. Leave SMTP_HOST
# or SMTP_USER empty to disable sending (emails are logged only).
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# App URL (for email links)
APP_URL="https://animationstation.ai"
FRONTEND_DEEP_LINK="animationstation://"

# Geo-IP (optional - falls back to ip-api.com free tier)
GEOIP_API_KEY=""

# Apple In-App Purchases — App Store Server Notifications V2 + Server API
APPLE_BUNDLE_ID="ai.animationstation.app"
APPLE_APP_APPLE_ID="numeric_app_id_from_app_store_connect"
# "Production" for the live app, "Sandbox" for the dev server / TestFlight
APPLE_ENVIRONMENT="Production"
# Leave unset to use the default ./certs/apple (relative to the container WORKDIR
# /app). The Apple root CA .cer files are committed in backend/certs/apple/.
# APPLE_ROOT_CERTS_DIR="certs/apple"
# App Store Server API key — only needed for admin "Refresh from Apple".
# The .p8 is gitignored; place it in backend/certs/ so the Dockerfile's
# `COPY certs ./certs` bakes it into the image. Path is relative to /app.
APPLE_API_KEY_ID="10_char_key_id"
APPLE_API_KEY_ISSUER_ID="issuer_uuid_from_users_and_access_integrations"
APPLE_API_KEY_PATH="certs/AuthKey_<KEYID>.p8"

# Stripe — web-only credit/subscription purchases (mobile stays Apple IAP).
# Secret key: Dashboard → Developers → API keys (use a RESTRICTED key with
# Checkout Sessions, Billing Portal, Customers, and Subscriptions write access
# if this Stripe account is shared with other projects).
STRIPE_SECRET_KEY=""
# Webhook signing secret for POST /api/webhooks/stripe. For local dev, run
# `stripe listen --forward-to localhost:3000/api/webhooks/stripe` and use the
# `whsec_...` it prints. In the Dashboard: Developers → Webhooks → this
# endpoint → Signing secret. Subscribe the endpoint to: checkout.session.completed,
# customer.subscription.updated, customer.subscription.deleted.
STRIPE_WEBHOOK_SECRET=""

# AWS CloudWatch Logs (optional). When CLOUDWATCH_LOG_GROUP is set, the backend
# ships structured Winston logs to that group via the animationstation-log-shipper IAM user.
# Leave unset in dev and any environment that shouldn't ship logs to AWS.
# Credentials are SEPARATE from the backend's S3 keys to keep IAM scopes
# minimal — the log shipper is write-only on /animationstation/* log groups.
CLOUDWATCH_LOG_GROUP=""
CLOUDWATCH_AWS_ACCESS_KEY_ID=""
CLOUDWATCH_AWS_SECRET_ACCESS_KEY=""
CLOUDWATCH_AWS_REGION="us-east-1"

# Sentry (error tracking / crash reporting). The ENTIRE integration is gated on
# SENTRY_DSN — leave it empty to disable (the SDK becomes a no-op, no events sent).
# Get the DSN from your Sentry project: Settings → Projects → <project> → Client
# Keys (DSN). Safe to commit elsewhere (it's an ingest key, not a secret), but we
# keep it in .env for per-environment control.
SENTRY_DSN=""
# Tag events with an environment. NODE_ENV is "production" on BOTH the prod and
# dev boxes, so set this explicitly to tell them apart in the Sentry UI:
# "production" on prod, "development" on the dev server. If unset, it's derived
# from APP_URL (api-dev → development).
SENTRY_ENVIRONMENT=""
# Optional. Groups issues by deploy. Pass a git SHA at deploy time, or leave unset
# to fall back to the backend package version (animationstation-backend@<version>).
SENTRY_RELEASE=""
# Performance tracing sample rate (0.0–1.0). Default 0 = errors only (recommended
# — transaction volume burns the free-tier quota fast). Set e.g. 0.1 to sample 10%.
SENTRY_TRACES_SAMPLE_RATE="0"
# Optional — powers the admin dashboard's "recent Sentry issues" panel. Create an
# org auth token (Settings → Auth Tokens) with project:read + event:read scope.
# Without these the dashboard still shows config status + a deep link, just no
# inline issue list. SENTRY_API_BASE is only for self-hosted Sentry.
SENTRY_AUTH_TOKEN=""
SENTRY_ORG_SLUG=""
SENTRY_PROJECT_SLUG=""
# SENTRY_API_BASE="https://sentry.io"

# Content-moderation strike alerting. Admins (ADMIN_EMAILS) are emailed on every
# Nth creation generation a single user gets blocked by Grok's content policy
# (repeat banned-content attempts). Default 3 — raise once you know normal volume.
MODERATION_STRIKE_ALERT_EVERY="3"
# Splash / announcement screen. Directory holding the optional launch splash
# image (splash.jpg/png/webp). File present = the app shows it on launch behind
# an OK gate; absent = normal startup. Bind-mounted from backend/splash/ in
# docker-compose, so publish/replace/remove never needs a rebuild. Manage it
# from the Admin Dashboard → Settings, or drop a file in the dir directly.
# SPLASH_DIR="./splash"
