{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true
  },
  // Transpile-only when run under ts-node (the test runner uses `-r ts-node/register`).
  // Matches the `--transpile-only` flag ts-node-dev already uses for `npm run dev`,
  // so type errors are caught by `npm run build` / `tsc --noEmit`, not at test time.
  "ts-node": { "transpileOnly": true },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "prisma", "**/*.test.ts"]
}
